# Variables de Entorno - Scraper TIBESA Backend
# Copia este archivo a `.env` y rellena los valores reales.
# El archivo `.env` está ignorado por git — nunca lo comitees.

# ============================================
# OPENAI (Scraper inmobiliario + brochure)
# ============================================
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4o-mini

# ============================================
# SCRAPER INMOBILIARIO (Playwright)
# ============================================
HEADLESS_MODE=true
DOWNLOAD_IMAGES=true

# ============================================
# MÓDULO DE LEADS (Google Places, FB Ads/Pages, CRM)
# ============================================

# Supabase — base de datos de usuarios y jobs
SUPABASE_URL=https://urxuebohedbjydwaedua.supabase.co
SUPABASE_KEY=

# Apify — plataforma de scraping SaaS
APIFY_API_TOKEN=

# URL pública del backend (EasyPanel), para que Apify devuelva los webhooks
# Ejemplo: https://scrapers-scraper-1.u3hhqk.easypanel.host
WEBHOOK_BASE_URL=

# CRM de TIBESA — token de autorización para enviar leads
CRM_TIBESA_API_TOKEN=
